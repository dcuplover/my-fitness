      { "name": "淀粉", "quantity": 5, "unit": "g" }
    ],
    "instructions": "1. 糙米提前浸泡2小时，放入电饭煲按正常水量煮饭\n2. 牛里脊逆纹切薄片，用生抽、淀粉、少许油腌制15分钟\n3. 西兰花切小朵焯水2分钟\n4. 锅烧热加橄榄油，大火快炒牛肉片至变色捞出\n5. 锅中加入西兰花翻炒，加蚝油调味\n6. 倒回牛肉片，撒黑胡椒，翻炒均匀\n7. 配糙米饭盛盘",
    "calories_per_serving": 420,
    "protein_per_serving": 35,
    "fat_per_serving": 10,
    "carbs_per_serving": 45,
    "servings": 1,
    "prep_time_min": 25,
    "cook_time_min": 20,
    "tags": "均衡,减脂主食,高蛋白,牛肉",
    "rating": 0,
