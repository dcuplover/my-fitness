[
  {
    "id": "seed-recipe-001",
    "name": "清蒸鸡胸肉",
    "description": "高蛋白低脂的经典减脂餐，鸡胸肉搭配少许调味料清蒸，保留原汁原味",
    "category": "高蛋白",
    "ingredients": [
      { "name": "鸡胸肉", "quantity": 200, "unit": "g" },
      { "name": "生姜", "quantity": 10, "unit": "g" },
      { "name": "葱", "quantity": 15, "unit": "g" },
      { "name": "料酒", "quantity": 10, "unit": "ml" },
      { "name": "盐", "quantity": 2, "unit": "g" },
      { "name": "生抽", "quantity": 5, "unit": "ml" }
    ],
    "instructions": "1. 鸡胸肉洗净，用刀背拍松，两面划几刀便于入味\n2. 用料酒、盐、生抽腌制15分钟\n3. 姜切片，葱切段，铺在盘底\n4. 将腌好的鸡胸肉放在姜葱上\n5. 水开后大火蒸15分钟\n6. 取出后可切片，淋上少许蒸鱼豉油即可",
