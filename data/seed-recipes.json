  {
    "id": "seed-recipe-003",
    "name": "番茄鸡蛋汤",
    "description": "家常经典汤品，番茄富含番茄红素，热量低饱腹感强",
    "category": "汤品",
    "ingredients": [
      { "name": "番茄", "quantity": 200, "unit": "g" },
      { "name": "鸡蛋", "quantity": 100, "unit": "g" },
      { "name": "葱花", "quantity": 5, "unit": "g" },
      { "name": "盐", "quantity": 2, "unit": "g" },
      { "name": "香油", "quantity": 3, "unit": "ml" },
      { "name": "水", "quantity": 500, "unit": "ml" }
    ],
    "instructions": "1. 番茄洗净，顶部划十字，用开水烫去皮，切小块\n2. 鸡蛋打散备用\n3. 锅中加少许油，放入番茄块翻炒出汁\n4. 加入清水，大火烧开\n5. 转小火煮5分钟，让番茄充分出味\n6. 缓缓倒入蛋液，用筷子轻轻搅散成蛋花\n7. 加盐调味，撒葱花，淋香油即可",
    "calories_per_serving": 95,
